<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        x:Class="Prog_part1.MainWindow"
        Title="Cybersecurity Awareness Chatbot v2.1" 
        Height="650" Width="800"
        Background="#0B0F19" 
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111827" CornerRadius="8" Padding="10" Margin="0,0,0,15" BorderBrush="#1F2937" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="🛡️ CYBERSECURITY INTELLIGENCE CORE" Foreground="#06B6D4" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Name="AsciiArtHeader" FontFamily="Courier New, Monospace" FontSize="7" Foreground="#22D3EE" HorizontalAlignment="Center" Margin="0,5,0,0" TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#111827" CornerRadius="8" BorderBrush="#1F2937" BorderThickness="1" Padding="5">
            <ScrollViewer Name="ChatScroll">
                <TextBlock Name="ChatDisplay" TextWrapping="Wrap" Foreground="#F9FAFB" FontSize="13" FontFamily="Courier New, Monospace" VerticalAlignment="Top" Padding="10"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Name="TxtInput" Grid.Column="0" Height="40" Background="#1F2937" Foreground="#FFFFFF" BorderBrush="#374151" BorderThickness="1" Padding="8,5" FontSize="13" VerticalContentAlignment="Center" KeyDown="TxtInput_KeyDown"/>
            <Button Name="BtnSend" Grid.Column="1" Content="TRANSMIT" Width="120" Margin="10,0,0,0" Background="#06B6D4" Foreground="#111827" FontWeight="Bold" FontSize="12" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="BtnSend_Click"/>
        </Grid>
    </Grid>
</Window>